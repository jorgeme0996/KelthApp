{
  "id": "lowcarb_masa_muscular",
  "name": "Ganancia de Masa Muscular",
  "source": "Ganancia de Masa Muscular - KelthSense",
  "description": "Plan para GANANCIA DE MASA MUSCULAR con la PROTEÍNA como prioridad. Versión flexible y menos restrictiva: la proteína manda (fuentes libres y carne roja/cerdo permitidos casi a diario), acompañada de carbohidratos abundantes alrededor del entrenamiento para sostener el superávit calórico y el rendimiento. Se sigue evitando solo lo claramente contraproducente (azúcar añadida en exceso, frituras, alcohol y ultraprocesados). Se recomiendan 5 comidas al día.",
  "goal": "ganancia_muscular",
  "proteinGuidance": {
    "prioridad": "La proteína es el eje del plan: debe cubrirse ANTES que cualquier otro grupo en cada comida.",
    "objetivo": "1.8 a 2.4 g de proteína por kg de peso corporal al día",
    "distribucion": "30-50 g de proteína en cada una de las 5 comidas. Empezar cada plato eligiendo primero la fuente proteica.",
    "fuentesRecomendadas": [
      "Pollo",
      "Pavo",
      "Pescado",
      "Huevo/claras",
      "Res magra",
      "Cerdo magro",
      "Yoghurt griego",
      "Proteína en polvo (whey o cero carb)",
      "Atún",
      "Mariscos"
    ],
    "postEntrenamiento": "Fuente de proteína (30-40 g) + 1-2 equivalentes de cereal o fruta dentro de la hora posterior al entrenamiento.",
    "notas": "Se admite proteína en polvo como colación o refuerzo. La carne roja y el cerdo dejan de estar limitados y pueden usarse casi a diario en cortes magros."
  },
