DATABASE_URL="postgresql://elmejormenu:elmejormenu@localhost:5434/elmejormenu?schema=public"
JWT_SECRET="change-this-to-a-long-random-string"
ANTHROPIC_API_KEY="sk-ant-..."
PORT=4000

# URL pública de esta API (usada para armar el enlace de restablecimiento de contraseña)
APP_URL="http://localhost:4000"
# Scheme de deep link de la app móvil (ver app/app.json -> expo.scheme)
APP_SCHEME="elmejormenu"

# SMTP para enviar correos (restablecimiento de contraseña). Si se omite, el
# enlace se imprime en la consola del servidor en vez de enviarse por correo.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="El Mejor Menú <no-reply@elmejormenu.app>"

# Base URL para el media de ejercicios (bucket S3 "el-mejor-menu-exercices" o su CDN);
# las rutas relativas image/gifUrl del dataset se concatenan a esta URL.
EXERCISE_MEDIA_BASE_URL="https://el-mejor-menu-exercices.s3.us-east-2.amazonaws.com"

# Stripe (suscripciones premium: $189/mes o $1,899/año)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_MONTHLY="price_..."
STRIPE_PRICE_ID_ANNUAL="price_..."

# Límite semanal de regenerar/cambiar comidas y ejercicios para usuarios freemium
FREEMIUM_WEEKLY_ACTION_LIMIT=5

# Días de prueba Premium gratuita al registrarse (reverse trial, sin tarjeta)
TRIAL_DAYS=7
# Hora (0-23, hora de Ciudad de México) en que corre el cron de recordatorio de fin de prueba
TRIAL_REMINDER_HOUR=10

# Zernio (WhatsApp vía docs.zernio.com) — API key oficial del SDK @zernio/node
ZERNIO_API_KEY="sk_..."
ZERNIO_WEBHOOK_SECRET=""
ZERNIO_WHATSAPP_ACCOUNT_ID=""

# Nombres de los templates de WhatsApp aprobados por Meta en Zernio
ZERNIO_TEMPLATE_BREAKFAST="desayuno_recordatorio"
ZERNIO_TEMPLATE_LUNCH="comida_rutina_recordatorio"
ZERNIO_TEMPLATE_EVENING="resumen_noche"

# Horas (0-23, hora de Ciudad de México) en que corren los cron jobs de WhatsApp
# NOTA: el envío por WhatsApp está pausado por el momento; los recordatorios
# se mandan por push notification (ver PUSH_*_REMINDER_HOUR abajo).
WHATSAPP_BREAKFAST_REMINDER_HOUR=8
WHATSAPP_LUNCH_REMINDER_HOUR=14
WHATSAPP_EVENING_REMINDER_HOUR=20

# Horas (0-23, hora de Ciudad de México) en que corren los cron jobs de
# recordatorios por push notification (vía Expo Push API, sin credenciales)
PUSH_BREAKFAST_REMINDER_HOUR=8
PUSH_LUNCH_REMINDER_HOUR=14
PUSH_EVENING_REMINDER_HOUR=20
