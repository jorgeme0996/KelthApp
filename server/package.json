{
  "name": "kelthapp-server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "prisma migrate deploy && npm run seed:exercises && npm run seed && node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node --transpile-only src/scripts/seed.ts",
    "seed:exercises": "ts-node --transpile-only src/scripts/seedExercises.ts",
    "test:whatsapp": "ts-node --transpile-only src/scripts/testWhatsappReminder.ts",
    "test:plan-expiration": "ts-node --transpile-only src/scripts/testPlanExpiration.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^5.20.0",
    "@zernio/node": "^0.2.335",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.8",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "stripe": "^22.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
