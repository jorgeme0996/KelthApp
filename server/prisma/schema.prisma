generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  mealsPerDay    Int      @default(4)
  exerciseDaysPerWeek Int?
  dietType       String   @default("lowcarb")
  dailyChatLimit Int?
  age            Int?
  heightCm       Int?
  weightKg       Float?
  goal           String?  // bajar_peso | mantener_peso | subir_masa
  gender              String?  // hombre | mujer | prefiero_no_decir
  splitType           String   @default("fullbody") // fullbody | split
  equipmentPreference String   @default("gym")       // gym | home
  dietaryRestrictions String[] @default([])          // vegetariano | vegano | sin_lacteos | sin_nueces | sin_mariscos | sin_gluten
  trainingDays        Int[]    @default([])          // 0-6 (Lun-Dom), días específicos elegidos por el usuario
  phone               String?
  pushToken           String?  // Expo push token del último dispositivo donde inició sesión
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?   // active | trialing | past_due | canceled | incomplete | unpaid
  subscriptionPlan     String?   // monthly | annual
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  trialReminderSentAt  DateTime?
  createdAt      DateTime @default(now())

  mealPlans           MealPlan[]
  routines            Routine[]
  chatMessages        ChatMessage[]
  passwordResetTokens PasswordResetToken[]
  workoutCompletions  WorkoutCompletion[]
  weeklyActionUsages  WeeklyActionUsage[]
}

model WeeklyActionUsage {
  id        String   @id @default(uuid())
  userId    String
  weekStart DateTime // Monday 00:00, same boundary as MealPlan/Routine weekStart
  count     Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

model WhatsappWebhookEvent {
  id         String   @id // Zernio's event UUID, used as the PK for idempotency dedupe
  eventType  String
  receivedAt DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Recipe {
  id          String   @id @default(uuid())
  name        String
  mealSlots   String[] // e.g. ["desayuno", "colacion_am"]
  cuisineTags String[] // e.g. ["mexicano"]
  ingredients Json     // [{ name, qty, unit, category }]
  steps       String[]
  equivalents Json     // { cereal: 1, proteina: 1, grasa: 1, ... }
  weeklyLimited Boolean @default(false) // true for recipes using res/cerdo/mariscos (max 1x/semana)
  prepTimeMinutes Int?  // total time to prepare the dish, in minutes
  dietType    String   @default("lowcarb")
  source      String   @default("seed") // seed | recipe_book | ai_generated
  createdAt   DateTime @default(now())

  entries MealPlanEntry[]
}

model MealPlan {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime
  mealsPerDay Int
  createdAt   DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries MealPlanEntry[]

  @@index([userId])
}

model MealPlanEntry {
  id          String    @id @default(uuid())
  mealPlanId  String
  dayIndex    Int // 0-6 (Mon-Sun)
  mealSlot    String // desayuno | colacion_am | comida | colacion_pm | cena
  recipeId    String
  completedAt DateTime? // set when the user checks this meal off as done

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@index([mealPlanId])
}

model Exercise {
  id               String   @id // dataset id, e.g. "0001"
  name             String
  bodyPart         String
  equipment        String
  instructions     String
  instructionSteps String[]
  muscleGroup      String
  secondaryMuscles String[]
  target           String
  image            String? // relative path, e.g. "images/0001-2gPfomN.jpg"; null for AI-generated exercises pending media backfill
  gifUrl           String? // relative path, e.g. "videos/0001-2gPfomN.gif"; null for AI-generated exercises pending media backfill
  attribution      String
  source           String   @default("seed") // seed | ai_generated
  createdAt        DateTime @default(now())

  entries RoutineEntry[]
}

model Routine {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime
  daysPerWeek Int
  createdAt   DateTime @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     RoutineEntry[]
  completions WorkoutCompletion[]

  @@index([userId])
}

model RoutineEntry {
  id              String @id @default(uuid())
  routineId       String
  dayIndex        Int // 0-6 (Mon-Sun); only workout days get entries
  bodyPart        String // denormalized, mirrors mealSlot's role
  exerciseId      String
  sets            Int
  reps            Int?
  durationSeconds Int? // set for cardio-style entries instead of reps

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([routineId])
}

model WorkoutCompletion {
  id            String   @id @default(uuid())
  userId        String
  routineId     String
  dayIndex      Int // 0-6 (Mon-Sun)
  bodyParts     String[] // snapshot of body parts trained, kept even if the routine changes later
  exerciseNames String[] // snapshot of exercise names trained
  completedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([routineId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String // user | assistant
  content   String
  channel   String   @default("app") // app | whatsapp
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
